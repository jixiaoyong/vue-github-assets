{
  "name": "@jixiaoyong/vue-github-assets",
  "version": "0.1.1",
  "type": "module",
  "description": "A Vue 3 plugin for managing image assets in GitHub repositories",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "dev": "vite --host",
    "prepare": "npm run build",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "example": "npm run dev --prefix example"
  },
  "peerDependencies": {
    "@octokit/rest": "^19.0.0 || ^20.0.0 || ^21.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@octokit/rest": "^21.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^27.3.0",
    "typescript": "^5.3.0",
    "vite": "^7.2.7",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.0.0",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^4.0.15",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": [
    "vue",
    "vue3",
    "github",
    "assets",
    "image",
    "upload",
    "cdn"
  ],
  "author": "jixiaoyong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jixiaoyong/vue-github-assets.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "libheif-js": "^1.19.8",
    "lucide-vue-next": "^0.460.0",
    "piexifjs": "^1.0.6"
  }
}
